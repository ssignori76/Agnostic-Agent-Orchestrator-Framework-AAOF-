# .env.example — Environment Variables Template
#
# Purpose: Documents all required environment variables for the project.
#          Copy this file to .env and fill in the actual values.
#          NEVER commit .env to git — only .env.example.
#
# Usage:   cp .env.example .env

# ─── Project ──────────────────────────────────────────────────────────────
PROJECT_NAME=my-project
APP_VERSION=1.0.0

# ─── API Configuration ────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=myapp_user
DB_PASSWORD=CHANGE_ME_IN_ENV

# ─── Application Secrets ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_IN_ENV
SESSION_SECRET=CHANGE_ME_IN_ENV

# ─── External Services (if applicable) ────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASSWORD=CHANGE_ME_IN_ENV
